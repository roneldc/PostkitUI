@page "/about"
<PageTitle>About Postkit</PageTitle>

<div class="container py-5 mt-1">

    <header class="mb-5 text-center">
        <h1 class="display-4 fw-bold text-dark">About Postkit</h1>
        <p class="lead">
            Postkit is a hosted Web API platform built with ASP.NET Core for adding modern social features to your apps.
            It handles posts, comments, reactions, and real-time notifications — no backend setup required.
        </p>
    </header>

    <hr class="my-5" />

    <section class="row align-items-start mb-5">
        <!-- Purpose -->
        <div class="col-md-6 mb-4 mb-md-0">
            <h2 class="h5 fw-bold text-dark">Purpose</h2>
            <p>
                Postkit provides developers with a plug-and-play API to accelerate app development.
                It eliminates the need to build or host a backend from scratch by exposing ready-to-use, secure, and modular endpoints.
            </p>
        </div>

        <!-- Powered By -->
        <div class="col-md-6">
            <h2 class="h5 fw-bold text-dark">Powered By</h2>
            <div class="row row-cols-2 g-2">
                <div class="col">
    <div class="border rounded p-3 bg-light small">
        ◾ ASP.NET Core 8 (Web API)
    </div>
</div>
<div class="col">
    <div class="border rounded p-3 bg-light small">
        ◾ Entity Framework Core
    </div>
</div>
<div class="col">
    <div class="border rounded p-3 bg-light small">
        ◾ MSSQL (SQL Server)
    </div>
</div>
<div class="col">
    <div class="border rounded p-3 bg-light small">
        ◾ ASP.NET Identity + JWT Auth
    </div>
</div>
<div class="col">
    <div class="border rounded p-3 bg-light small">
        ◾ API Key Security Headers
    </div>
</div>
<div class="col">
    <div class="border rounded p-3 bg-light small">
        ◾ SignalR (Real-time)
    </div>
</div>
<div class="col">
    <div class="border rounded p-3 bg-light small">
        ◾ Cloudinary (Media Uploads)
    </div>
</div>
<div class="col">
    <div class="border rounded p-3 bg-light small">
        ◾ Mailjet (Email Notifications)
    </div>
</div>
<div class="col">
    <div class="border rounded p-3 bg-light small">
        ◾ Swagger / OpenAPI Docs
    </div>
</div>
<div class="col">
    <div class="border rounded p-3 bg-light small">
        ◾ xUnit Testing
    </div>
</div>
            </div>
        </div>
    </section>


    <hr class="my-5" />

    <div class="row">
        <div class="col-md-6 mb-4">
            <h2 class="h5 fw-bold text-dark">What's Next</h2>
            <ul>
                <li>User mentions and tagging support</li>
                <li>AI-powered content filtering for posts and comments, with context-awareness based on the app’s theme</li>
                <li>Basic moderation endpoints (hide, delete, report)</li>
                <li>Rate limiting and request throttling for abuse prevention</li>
            </ul>
        </div>
        <div class="col-md-6 mb-4">
            <h2 class="h5 fw-bold text-dark">Who Should Use Postkit?</h2>
            <p>
                Postkit is perfect for developers who want to focus on front-end features and skip backend boilerplate. Ideal for:
            </p>
            <ul>
                <li>.NET developers prototyping social platforms</li>
                <li>Students learning clean API design</li>
                <li>Startups launching MVPs with UGC</li>
            </ul>
        </div>
    </div>

    <hr class="my-5" />

    <section class="text-center">
        <p class="text-muted mb-1">
            API built by
            <strong>John Ronel Dela Cruz</strong> —
            Full-stack Software Engineer from the Philippines.
        </p>
        <p class="text-muted">
            Source available on
            <a href="https://github.com/roneldc/PostkitAPI.git" target="_blank" class="text-primary fw-semibold text-decoration-underline">
                GitHub
            </a> • Licensed under the <strong>MIT License</strong>
        </p>
    </section>

</div>
