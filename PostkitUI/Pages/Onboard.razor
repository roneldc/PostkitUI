@page "/onboard"
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<EditForm Model="formModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />

    <div class="container mt-5">
        <header class="mb-5 text-center">
            <h1 class="display-4 fw-bold text-dark">Get API Access</h1>
            <p class="lead text-muted">
                Provide your app name and email to request and confirm access to your API key.
            </p>
        </header>

        <div class="row justify-content-center">
            <!-- Left Column: Form -->
            <div class="col-lg-5 col-md-5 d-flex align-items-center">
                <div class="p-4">
                    <h4 class="fw-bold">How It Works</h4>
                    <p class="text-muted">
                        After submitting your details, you’ll receive an email confirmation link.
                        Once you confirm, we’ll send you your <strong>API credentials</strong> and
                        <strong>admin login details</strong> so you can start managing your app right away.
                    </p>
                    <ul class="list-unstyled">
                        <li>✓ One-click email confirmation</li>
                        <li>✓ Immediate access to API credentials</li>
                        <li>✓ Admin login to manage your app</li>
                    </ul>
                </div>
            </div>

            <!-- Right Column: Info / Illustration -->
            <div class="col-lg-6 col-md-7">
                <div class="card shadow-sm rounded-3 h-100">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label for="appName" class="form-label">App Name</label>
                            <InputText id="appName" class="form-control" @bind-Value="formModel.AppName" />
                            <ValidationMessage For="@(() => formModel.AppName)" />
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address</label>
                            <InputText id="email" type="email" class="form-control" @bind-Value="formModel.Email" />
                            <ValidationMessage For="@(() => formModel.Email)" />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary" disabled="@isSending">
                                @(isSending ? "Sending..." : "Send Verification Email")
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="alert alert-success mt-3">@successMessage</div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger mt-3">@errorMessage</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</EditForm>


@code {
    private ApiVerificationModel formModel = new();
    private string? successMessage;
    private string? errorMessage;
    private bool isSending = false;

    private async Task HandleValidSubmit()
    {
        isSending = true;
        try
        {
            var resp = await Http.PostAsJsonAsync("/ui/tenants", formModel);

            if (resp.IsSuccessStatusCode)
            {
                successMessage = "Success! Please verify via the confirmation email we've sent.";
                errorMessage = null;
            }
            else
            {
                var error = await resp.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMessage = error?.Message ?? "An unexpected error occurred.";
                successMessage = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred. Please try again or contact support.";
            successMessage = null;
        }
        finally
        {
            isSending = false;
            formModel = new ApiVerificationModel();
        }
    }

    public class ApiVerificationModel
    {
        [Required(ErrorMessage = "App Name is required")]
        public string? AppName { get; set; }

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string? Email { get; set; }
    }

    public class ErrorResponse
    {
        public string? Message { get; set; }
    }
}